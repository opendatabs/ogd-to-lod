@prefix cube: <https://cube.link/> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ld.bs.ch/100243> a cube:Cube ;
    schema:name "Rhein Wasserstand Klingentalfähre" ;
    schema:description "Dieser Datensatz zeigt den Wasserstand des Rheins in Basel auf der Grossbasler Seite auf Höhe der Klingentalfähre. Es liegen aktuelle Werte alle 5 Minuten vor. Die Messungen werden im Auftrag des Bundesamts für Umwelt durchgeführt (siehe https://www.hydrodaten.admin.ch/de/seen-und-fluesse/stationen-und-daten/2615)." ;
    schema:publisher "Bundesamt für Umwelt BAFU" ;
    dcterms:issued "2021-01-24"^^xsd:date ;
    dcterms:modified "2020-12-04"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/deed.de> ;
    schema:keywords "Rhein", "Pegel", "Wasserstand", "Wasser", "Tiefe" ;
    cube:observationSet <https://ld.bs.ch/100243/observation-set> .

<https://ld.bs.ch/100243/observation-set> a cube:ObservationSet .

<https://ld.bs.ch/property/ZEIT> a cube:KeyDimension ;
    schema:name "timestamp" ;
    schema:description "Datum und Uhrzeit" .

<https://ld.bs.ch/property/RAUM> a cube:KeyDimension ;
    schema:name "spatial_coverage" .

<https://ld.bs.ch/property/pegel> a cube:MeasureDimension ;
    schema:name "pegel" ;
    schema:description "Pegelstand in Metern über Meer" .
