@prefix cube: <https://cube.link/> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ld.bs.ch/100323> a cube:Cube ;
    schema:name "Rheintrübung kontinuierlich" ;
    schema:description "Kontinuierlich gemessene Trübungsmesswerte der Rheinüberwachungsstation Weil am Rhein (RUES, siehe https://www.bs.ch/wsu/aue/abteilung-umweltlabor/rheinueberwachungsstation-weil-am-rhein-rues), jeweils gemittelt über eine Stunde.\n\nErklärung zur Einheit: Die Trübung einer Flüssigkeit wird optisch ermittelt, jedoch mittels elektronischer Auswertung gemessen. Die Wellenlänge der Mess-Strahlung liegt üblicherweise im Infrarotbereich bei 860 nm (nach ISO 7027).\n\nFNU: Formazine Nephelometric Unit – Streulichtmessung (Winkel 90°) gemäß den Vorschriften der Norm ISO 7027\n\nMessbetrieb / Unterhalt: Amt für Umwelt und Energie Basel-Stadt (AUE-BS) (siehe https://www.bs.ch/wsu/aue)" ;
    schema:publisher "Amt für Umwelt und Energie" ;
    dcterms:issued "2023-11-23"^^xsd:date ;
    dcterms:modified "2023-10-19"^^xsd:date ;
    dcterms:license "CC0 1.0" ;
    schema:keywords "Baden", "Lichtdurchlässigkeit", "Rhein", "Trübung" ;
    cube:observationSet <https://ld.bs.ch/100323/observation-set> .

<https://ld.bs.ch/100323/observation-set> a cube:ObservationSet .

<https://ld.bs.ch/property/ZEIT> a cube:KeyDimension ;
    schema:name "startzeitpunkt" ;
    schema:description "Start der Messung" .

<https://ld.bs.ch/property/rus_w_o_ms_tr> a cube:MeasureDimension ;
    schema:name "rus_w_o_ms_tr" ;
    schema:description "Stundenmittelwert der Trübung gemessen in FNU (\"Formazin Nephelometric Unit\", was auf Deutsch \"Nephelometrische Formazin-Einheit\" bedeutet)" .
