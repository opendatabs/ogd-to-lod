@prefix cube: <https://cube.link/> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ld.bs.ch/100235> a cube:Cube ;
    schema:name "Wiese Wasserstand und Abfluss" ;
    schema:description "Dieser Datensatz zeigt den Wasserstand und die Abflussmenge der Wiese in Basel etwa auf Höhe der Brücke bei der Wiesenstrasse über die Wiese. Es liegen aktuelle Werte alle 5 Minuten vor. Die Messungen werden im Auftrag des Bundesamts für Umwelt durchgeführt (siehe https://www.hydrodaten.admin.ch/de/seen-und-fluesse/stationen-und-daten/2199)." ;
    schema:publisher "Bundesamt für Umwelt BAFU" ;
    dcterms:issued "2022-11-10"^^xsd:date ;
    dcterms:modified "2022-11-01"^^xsd:date ;
    dcterms:license "CC0 1.0" ;
    schema:keywords "Abflussmenge", "Strömung", "Tiefe", "Wasser", "Wasserstand", "Wiese" ;
    cube:observationSet <https://ld.bs.ch/100235/observation-set> .

<https://ld.bs.ch/100235/observation-set> a cube:ObservationSet .

<https://ld.bs.ch/property/ZEIT> a cube:KeyDimension ;
    schema:name "timestamp" ;
    schema:description "Datum und Uhrzeit" .

<https://ld.bs.ch/property/RAUM> a cube:KeyDimension ;
    schema:name "spatial_coverage" .

<https://ld.bs.ch/property/abfluss> a cube:MeasureDimension ;
    schema:name "abfluss" ;
    schema:description "Abfliessende Wassermenge in Kubikmetern pro Sekunde" .

<https://ld.bs.ch/property/pegel> a cube:MeasureDimension ;
    schema:name "pegel" ;
    schema:description "Pegelstand in Metern über Meer" .

<https://ld.bs.ch/property/temperatur> a cube:MeasureDimension ;
    schema:name "temperatur" .
