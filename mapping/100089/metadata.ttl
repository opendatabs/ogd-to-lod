@prefix cube: <https://cube.link/> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ld.bs.ch/100089> a cube:Cube ;
    schema:name "Rhein Wasserstand, Pegel und Abfluss" ;
    schema:description "Dieser Datensatz zeigt den Wasserstand und die Abflussmenge des Rheins in Basel auf der Kleinbasler Seite auf Höhe des Birs-Zuflusses. Es liegen aktuelle Werte alle 5 Minuten vor. Die Messungen werden im Auftrag des Bundesamts für Umwelt durchgeführt (siehe https://www.hydrodaten.admin.ch/de/seen-und-fluesse/stationen-und-daten/2289). Der Pegel wird berechnet als [Wasserstand] - 240 m ü. M., siehe https://port-of-switzerland.ch/hafenservice/pegel." ;
    schema:publisher "Bundesamt für Umwelt BAFU" ;
    dcterms:issued "2020-06-29"^^xsd:date ;
    dcterms:modified "2020-06-25"^^xsd:date ;
    dcterms:license "CC0 1.0" ;
    schema:keywords "Abflussmenge", "Pegel", "Rhein", "Strömung", "Tiefe", "Wasser", "Wasserstand" ;
    cube:observationSet <https://ld.bs.ch/100089/observation-set> .

<https://ld.bs.ch/100089/observation-set> a cube:ObservationSet .

<https://ld.bs.ch/property/ZEIT> a cube:KeyDimension ;
    schema:name "timestamp" ;
    schema:description "Datum und Uhrzeit" .

<https://ld.bs.ch/property/RAUM> a cube:KeyDimension ;
    schema:name "spatial_coverage" .

<https://ld.bs.ch/property/abfluss> a cube:MeasureDimension ;
    schema:name "abfluss" ;
    schema:description "Abfliessende Wassermenge in Kubikmetern pro Sekunde" ;
    schema:disambiguatingDescription "unit: m3/s" .

<https://ld.bs.ch/property/pegelhoehe> a cube:MeasureDimension ;
    schema:name "pegelhoehe" ;
    schema:description "Pegelstand in cm über dem Pegelnullstand von 240 m ü. M." ;
    schema:disambiguatingDescription "unit: cm" .

<https://ld.bs.ch/property/pegel> a cube:MeasureDimension ;
    schema:name "pegel" ;
    schema:description "Pegelstand in Metern über Meer" ;
    schema:disambiguatingDescription "unit: m" .
