@prefix cube: <https://cube.link/> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ld.bs.ch/100227> a cube:Cube ;
    schema:name "Witterung" ;
    schema:description "Dieser Datensatz zeigt für die Messstation Basel-Binningen am Observatorium St. Margarethen für jeden Monat die in Bezug auf Temperatur, Niederschlag und Bewölkung registrierten Witterungserscheinungen seit 1921.Methodischer Hinweis:Daten von 1921 bis 1940 stammen von der astronomisch-meteorologischen Anstalt im Bernoullianum." ;
    schema:publisher "Statistisches Amt" ;
    dcterms:license "CC BY 4.0" ;
    schema:keywords "Eistage", "Frosttage", "Gewitter", "Hagel", "Heizgradtage", "Hitzetage", "Klima", "Luft", "Nebel", "Reif", "Schneedecke", "Schneefall", "Sommertage", "Tage ohne Sonne", "Wind", "Zeitreihe" ;
    cube:observationSet <https://ld.bs.ch/100227/observation-set> .

<https://ld.bs.ch/100227/observation-set> a cube:ObservationSet .

<https://ld.bs.ch/property/ZEIT> a cube:KeyDimension ;
    schema:name "datum" ;
    schema:description "Monat und Jahr, in dem der Wert registriert wurde" .

<https://ld.bs.ch/property/RAUM> a cube:KeyDimension ;
    schema:name "raum" .

<https://ld.bs.ch/property/frosttag> a cube:MeasureDimension ;
    schema:name "frosttag" ;
    schema:description "Anzahl Tage mit Minimaltemperatur unter 0° Celsius" .

<https://ld.bs.ch/property/eistag> a cube:MeasureDimension ;
    schema:name "eistag" ;
    schema:description "Anzahl Tage mit Maximaltemperatur unter 0° Celsius" .

<https://ld.bs.ch/property/sommertag> a cube:MeasureDimension ;
    schema:name "sommertag" ;
    schema:description "Anzahl Tage mit Maximaltemperatur über 25° Celsius" .

<https://ld.bs.ch/property/hitzetag> a cube:MeasureDimension ;
    schema:name "hitzetag" ;
    schema:description "Anzahl Tage mit Maximaltemperatur über 30° Celsius" .

<https://ld.bs.ch/property/sonnenlos> a cube:MeasureDimension ;
    schema:name "sonnenlos" ;
    schema:description "Anzahl Tage mit 0 Sonnenstunden" .

<https://ld.bs.ch/property/regen1> a cube:MeasureDimension ;
    schema:name "regen1" ;
    schema:description "Anzahl Tage mit mindestens 0,1 mm Niederschlag" .

<https://ld.bs.ch/property/regen2> a cube:MeasureDimension ;
    schema:name "regen2" ;
    schema:description "Anzahl Tage mit mindestens 0,3 mm Niederschlag" .

<https://ld.bs.ch/property/regen3> a cube:MeasureDimension ;
    schema:name "regen3" ;
    schema:description "Anzahl Tage mit mindestens 1,0 mm Niederschlag" .

<https://ld.bs.ch/property/schneefall> a cube:MeasureDimension ;
    schema:name "schneefall" ;
    schema:description "Anzahl Tage mit Schneefall" .

<https://ld.bs.ch/property/schneedecke> a cube:MeasureDimension ;
    schema:name "schneedecke" ;
    schema:description "Anzahl Tage mit geschlossener Schneedecke" .

<https://ld.bs.ch/property/reif> a cube:MeasureDimension ;
    schema:name "reif" ;
    schema:description "Anzahl Tage mit Reif" .

<https://ld.bs.ch/property/nebel> a cube:MeasureDimension ;
    schema:name "nebel" ;
    schema:description "Anzahl Tage mit Nebel" .

<https://ld.bs.ch/property/gewitter1> a cube:MeasureDimension ;
    schema:name "gewitter1" ;
    schema:description "Anzahl Tage mit Nah- oder Ferngewitter" .

<https://ld.bs.ch/property/gewitter2> a cube:MeasureDimension ;
    schema:name "gewitter2" ;
    schema:description "Anzahl Tage mit Nahgewitter (<15 km Entfernung)" .

<https://ld.bs.ch/property/hagel> a cube:MeasureDimension ;
    schema:name "hagel" ;
    schema:description "Anzahl Tage mit Hagel" .

<https://ld.bs.ch/property/hell> a cube:MeasureDimension ;
    schema:name "hell" ;
    schema:description "Anzahl Tage mit höchstens 20% Bewölkung" .

<https://ld.bs.ch/property/trueb> a cube:MeasureDimension ;
    schema:name "trueb" ;
    schema:description "Anzahl Tage mit mindestens 80% Bewölkung" .

<https://ld.bs.ch/property/wind1> a cube:MeasureDimension ;
    schema:name "wind1" ;
    schema:description "Anzahl Tage mit Windgeschwindigkeiten über 15 m/sec" .

<https://ld.bs.ch/property/wind2> a cube:MeasureDimension ;
    schema:name "wind2" ;
    schema:description "Anzahl Tage mit Windgeschwindigkeiten über 26 m/sec" .

<https://ld.bs.ch/property/heiztage> a cube:MeasureDimension ;
    schema:name "heiztage" ;
    schema:description "Anzahl Tage, an denen die Heizgrenze von 12 °C unterschritten wird." .
