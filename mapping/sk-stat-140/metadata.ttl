@prefix cube: <https://cube.link/> .
@prefix schema: <http://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://ld.tg.ch/sk-stat-140> a cube:Cube ;
    schema:name "Politische Geschäfte des Grossen Rats des Kantons Thurgau" ;
    schema:description "Der Datensatz enthält die politischen Geschäfte des Grossen Rats seit 2008. Über die Geschäftsnummer kann der Datensatz mit weiteren Datensätzen zum Grossen Rat wie den Vorstösserinnen und Vorstösser oder den Dokumenten verbunden (\"gejoint\") werden.\n\nDie Daten stammen aus der elektronische Geschäftsdatenbank des Grossen Rats (GRGEKO) und werden täglich automatisiert aktualisiert.\n\nAufgrund einer Softwareumstellung kann das Abschlussdatum erst ab der Legislatur 2016 ausgewiesen werden." ;
    schema:publisher "Staatskanzlei Kanton Thurgau" ;
    dcterms:license "CC0 1.0" ;
    schema:keywords "Antrag", "Beschluss", "Einfache Anfrage", "GRGEKO", "Grosser Rat", "Grossrat", "Grossrätin", "Interpellation", "Kantonsparlament", "Kantonsrat", "Leistungsmotion", "Motion", "Parlament", "Parlamentarische Initiative", "Partei", "Petition", "Vorstoss", "Vorstösser", "Vorstösserin", "grdata" ;
    cube:observationSet <https://ld.tg.ch/sk-stat-140/observation-set> .

<https://ld.tg.ch/sk-stat-140/observation-set> a cube:ObservationSet .

<https://ld.tg.ch/property/ZEIT> a cube:KeyDimension ;
    schema:name "datum_geschaeft_eingang" ;
    schema:description "Eröffnungsdatum des Geschäfts" .

<https://ld.tg.ch/property/geschaeftsnummer> a cube:KeyDimension ;
    schema:name "geschaeftsnummer" ;
    schema:description "Geschäftsnummer" .

<https://ld.tg.ch/property/grg_nummer> a cube:KeyDimension ;
    schema:name "grg_nummer" ;
    schema:description "GRG-Nummer" .

<https://ld.tg.ch/property/geschaftstitel> a cube:KeyDimension ;
    schema:name "geschaftstitel" ;
    schema:description "Titel des Geschäfts" .

<https://ld.tg.ch/property/geschaftsart> a cube:KeyDimension ;
    schema:name "geschaftsart" ;
    schema:description "Art des Geschäfts" .

<https://ld.tg.ch/property/kennung> a cube:KeyDimension ;
    schema:name "kennung" ;
    schema:description "Kennung der Geschäftsart" .

<https://ld.tg.ch/property/sachbegriff_grgeko_1> a cube:KeyDimension ;
    schema:name "sachbegriff_grgeko_1" ;
    schema:description "Sachbegriff" .

<https://ld.tg.ch/property/sachbegriff_grgeko_2> a cube:KeyDimension ;
    schema:name "sachbegriff_grgeko_2" .

<https://ld.tg.ch/property/sachbegriff_grgeko_3> a cube:KeyDimension ;
    schema:name "sachbegriff_grgeko_3" .

<https://ld.tg.ch/property/status> a cube:KeyDimension ;
    schema:name "status" ;
    schema:description "Status des Geschäfts" .

<https://ld.tg.ch/property/departement> a cube:KeyDimension ;
    schema:name "departement" ;
    schema:description "Zuständiges Departement" .

<https://ld.tg.ch/property/RAUM> a cube:KeyDimension ;
    schema:name "spatial_coverage" .

<https://ld.tg.ch/property/anzahl_erstunterzeichnende> a cube:MeasureDimension ;
    schema:name "anzahl_erstunterzeichnende" ;
    schema:description "Anzahl der Erstunterzeichnenden (Vorstösser und Vorstösserinnen)" .

<https://ld.tg.ch/property/anzahl_mitunterzeichnende> a cube:MeasureDimension ;
    schema:name "anzahl_mitunterzeichnende" ;
    schema:description "Anzahl der Mitglieder des Grossen Rats, die den Vorstoss mitunterzeichnet haben" .

<https://ld.tg.ch/property/total_unterzeichnende> a cube:MeasureDimension ;
    schema:name "total_unterzeichnende" ;
    schema:description "Anzahl der Unterzeichnenden" .
